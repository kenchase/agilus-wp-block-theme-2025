          "fontFamily": "var(--wp--preset--font-family--sofia-pro-soft)",
          "fontStyle": "normal",
          "fontWeight": "300"
        }
      },
      "caption": {
        "color": {
          "text": "var(--wp--preset--color--dark)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--sofia-pro-soft)",
          "fontStyle": "normal",
          "fontWeight": "300"
        }
      },
