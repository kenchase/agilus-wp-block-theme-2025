          "color": {
            "text": "var(--wp--preset--color--ag-yellow-500)"
          }
        },
        "color": {
          "text": "var(--wp--preset--color--light)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--sofia-pro-soft)",
          "fontStyle": "normal",
          "fontWeight": "300"
        }
      }
    },
